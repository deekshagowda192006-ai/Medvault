{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for patient or doctor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "address": { "type": "string" },
        "degree": { "type": "string" },
        "sharingEnabled": { "type": "boolean" }
      },
      "required": ["id", "role", "name", "email"]
    },
    "Record": {
      "title": "Medical Record",
      "description": "Medical record uploaded by patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "fileURL": { "type": "string" },
        "type": { "type": "string", "enum": ["prescription", "report"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "patientId", "fileURL", "type", "createdAt"]
    },
    "Reminder": {
      "title": "Medication Reminder",
      "description": "Medicine reminders for patients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "medicine": { "type": "string" },
        "time": { "type": "string" },
        "frequency": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "userId", "medicine", "time"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/records/{recordId}": {
      "schema": "Record",
      "description": "Medical records"
    },
    "/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Medication reminders"
    }
  }
}
